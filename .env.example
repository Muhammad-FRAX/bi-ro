# ============================================================
# BI-Ro environment variables — copy to .env and fill in
# ============================================================

# --------------- App identity ---------------
APP_TITLE=BI Root
APP_ACCENT=#a78bfa

# --------------- Auth mode (immutable after first run) ---------------
# Choices: self | keycloak | ldap
AUTH_MODE=self

# --------------- Vault master key (CRITICAL — back this up securely) ---------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing this key = losing ALL team vault secrets permanently.
# Store in a password manager, a KMS, or an out-of-band backup BEFORE first use.
# NEVER commit this to version control.
BIRO_MASTER_KEK=REPLACE_ME_WITH_A_BASE64_32_BYTE_KEY

# --------------- Database ---------------
DATABASE_URL=postgres://biro:biro_password@bi-ro-db:5432/biro

# --------------- Session cookie secret (required) ---------------
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_SECRET

# --------------- First admin (env-seeded, per §22 E3) ---------------
# Used only on the very first boot to create the initial admin account.
# Force-change on first login. Remove or blank after first successful login.
BIRO_ADMIN_EMAIL=admin@example.com
BIRO_ADMIN_PASSWORD=CHANGE_ME_ON_FIRST_LOGIN

# --------------- SMTP (optional — for expiry alerts and notifications) ---------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=bi-ro@example.com

# --------------- Expiry notification thresholds (days before expiry) ---------------
EXPIRY_THRESHOLDS=7,2,0

# --------------- Keycloak (only if AUTH_MODE=keycloak) ---------------
# BI-Ro connects to an EXISTING external Keycloak — it does not run its own.
# For local testing, use: docker compose -f keycloak.test.compose.yaml up -d
#
# KEYCLOAK_ISSUER  = Realm URL, e.g. https://sso.company.com/realms/bi
# KEYCLOAK_CLIENT_ID     = Client ID created in Keycloak (type: Confidential, OpenID Connect)
# KEYCLOAK_CLIENT_SECRET = Client secret (Credentials tab in Keycloak)
# KEYCLOAK_REDIRECT_URI  = Must match the Valid Redirect URI in Keycloak client settings
# KEYCLOAK_DEFAULT_ROLE  = BI-Ro role assigned to newly provisioned users (default: viewer)
#
# Role mapping (group → BI-Ro role) is configured in Settings → Auth Mappings.
# Example: { "bi-admins": "admin", "bi-editors": "editor", "bi-team": "viewer" }
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/biro
KEYCLOAK_CLIENT_ID=bi-ro
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=https://biro.example.com/api/auth/keycloak/callback
KEYCLOAK_DEFAULT_ROLE=viewer

# --------------- LDAP / Active Directory (only if AUTH_MODE=ldap) ---------------
# BI-Ro uses the user's email as their AD bind DN (UPN format: user@domain.local).
# No service account is required — the user binds directly with their own credentials.
#
# LDAP_URL          = ldap://192.168.1.10:389  or  ldaps://192.168.1.10:636
# LDAP_BIND_TEMPLATE = Optional. If your AD uses SAM format, set to "{username}@domain.local"
#                      where {username} is replaced with the part before @ in the email.
#                      If unset, the full email is used as the bind DN (UPN format).
# LDAP_TLS          = true to enable LDAPS / StartTLS (auto-detected if URL starts with ldaps://)
#
# User setup: admin creates BI-Ro accounts in Settings → Users (authMode=ldap, no password).
# The account email must match the user's AD UPN / mail attribute exactly.
# The env-seeded admin (BIRO_ADMIN_EMAIL) always authenticates via password regardless of LDAP mode.
LDAP_URL=ldap://192.168.1.10:389
# LDAP_BIND_TEMPLATE={username}@company.local
LDAP_TLS=false

# --------------- Document uploads (volume path, default /uploads) ---------------
# Maps to the bi-ro-uploads Docker volume mount. Change only if mounting at a different path.
UPLOADS_DIR=/uploads

# --------------- Server ---------------
PORT=5000
NODE_ENV=production
