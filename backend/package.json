{
  "name": "bi-ro-backend",
  "version": "0.1.0",
  "description": "BI-Ro backend — Express 5 / TypeScript / PostgreSQL",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "build": "tsup src/server.ts --format esm --dts --out-dir dist",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "BI Team",
  "license": "ISC",
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^7.9.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.14.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.15.34",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.14",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
